schema_version: 4
demo:
  name: my-demo
  description: GridGain Demo Application
  stage: development
  ownership_tag: <YOUR_OWNERSHIP_TAG>
  gridgain9_license_file: cluster/gridgain-license.json
  gridgain8_license_file: cluster/gridgain8-license.xml
  controlcenter_license_file: controlcenter/controlcenter-license.xml
  log_ready_checks: false
  output_directory: build/gridgain/output
  runtime_directory: build/gridgain/.runtime
  working_directory: .
  demo_access:
    enabled: true
    max_exposed_nodes: 3
clusters:
  my-demo-gcp-9a:
    disabled: false
    template: gke-standard-v9
    infrastructure: staging-gcp
    k8s_namespace:
      name: demo-9a-servers
      exclusive_use: true
    k8s_service_name: demo-servers-9a-service
    data_models:
    - data/base-schema.yaml
    base_data: []
    monitoring:
      cc-gcp:
        connector_template: gke-connector
      pg-gcp:
        connector_template: gke-otel-collector
      nebula:
        connector_template: gke-connector
  my-demo-gcp-9b:
    disabled: false
    template: gke-standard-v9
    infrastructure: staging-gcp
    k8s_namespace:
      name: demo-9b-servers
      exclusive_use: true
    k8s_service_name: demo-servers-9b-service
    data_models:
    - data/base-schema.yaml
    base_data: []
    monitoring:
      cc-gcp:
        connector_template: gke-connector
      pg-gcp:
        connector_template: gke-otel-collector
  my-demo-gcp-8a:
    disabled: false
    template: gke-standard-v8
    infrastructure: staging-gcp
    k8s_namespace:
      name: demo-8a-servers
      exclusive_use: true
    k8s_service_name: demo-servers-8a-service
    data_models: []
    base_data: []
    monitoring:
      pg-gcp:
        connector_template: gke-otel-collector
      cc-gcp:
        connector_template: ignite-agent
      nebula:
        connector_template: ignite-agent
  my-demo-aws-9a:
    disabled: false
    template: eks-standard-v9
    infrastructure: staging-aws
    k8s_namespace:
      name: demo-9a-servers
      exclusive_use: true
    k8s_service_name: demo-servers-9a-service
    data_models:
    - data/base-schema.yaml
    base_data: []
    monitoring:
      cc-aws:
        connector_template: eks-connector
  my-demo-aws-8a:
    disabled: false
    template: eks-standard-v8
    infrastructure: staging-aws
    k8s_namespace:
      name: demo-8a-servers
      exclusive_use: true
    k8s_service_name: demo-servers-8a-service
    data_models: []
    base_data: []
    monitoring:
      cc-aws:
        connector_template: ignite-agent
      nebula:
        connector_template: ignite-agent
monitors:
  cc-gcp:
    type: control-center
    infrastructure: staging-gcp
    admin_email: <YOUR_ADMIN_EMAIL>
    admin_password: <YOUR_ADMIN_PASSWORD>
    num_nodes: 1
    min_nodes: 1
    max_nodes: 3
    k8s_namespace:
      name: gg-control-center
    k8s_node_pool_template: cc-gke-pool
    backend:
      image: gridgain/control-center-backend:latest
      replicas: 1
      exporter_target_port: 9090
      exporter_target_port_tls: 9443
      storage_port: 5432
      jvm_opts: ''
      resources:
        cpu_request: 500m
        memory_request: 1Gi
        cpu_limit: 2000m
        memory_limit: 2Gi
    frontend:
      image: gridgain/control-center-frontend:latest
      replicas: 1
      ui_port: 8008
      ui_port_tls: 8443
      resources:
        cpu_request: 100m
        memory_request: 256Mi
        cpu_limit: 500m
        memory_limit: 512Mi
    storage:
      retain_on_destroy: false
      disk_type: pd-standard
      storage_size: 10Gi
    timeouts:
      statefulset: 300
      deployment: 300
      login_url: 300
      load_balancer: 300
  cc-aws:
    disabled: false
    type: control-center
    infrastructure: staging-aws
    admin_email: <YOUR_ADMIN_EMAIL>
    admin_password: <YOUR_ADMIN_PASSWORD>
    num_nodes: 1
    min_nodes: 1
    max_nodes: 3
    k8s_namespace:
      name: gg-control-center
    k8s_node_pool_template: cc-eks-pool
    backend:
      image: gridgain/control-center-backend:latest
      replicas: 1
      exporter_target_port: 9090
      exporter_target_port_tls: 9443
      storage_port: 5432
      jvm_opts: ''
      resources:
        cpu_request: 500m
        memory_request: 1Gi
        cpu_limit: 2000m
        memory_limit: 2Gi
    frontend:
      image: gridgain/control-center-frontend:latest
      replicas: 1
      ui_port: 8008
      ui_port_tls: 8443
      resources:
        cpu_request: 100m
        memory_request: 256Mi
        cpu_limit: 500m
        memory_limit: 512Mi
    storage:
      retain_on_destroy: false
      disk_type: gp3
      storage_size: 10Gi
    timeouts:
      statefulset: 300
      deployment: 300
      login_url: 300
      load_balancer: 300
  nebula:
    type: nebula
    portal_url: https://portal.gridgain.com
    username: <YOUR_NEBULA_USERNAME>
    password: <YOUR_NEBULA_PASSWORD>
  pg-gcp:
    type: prometheus-grafana
    infrastructure: staging-gcp
    num_nodes: 1
    min_nodes: 1
    max_nodes: 3
    k8s_namespace:
      name: gg-prometheus-grafana
    k8s_node_pool_template: cc-gke-pool
    prometheus:
      image: prom/prometheus:v3.4.1
      replicas: 1
      scrape_port: 9090
      resources:
        cpu_request: 500m
        memory_request: 1Gi
        cpu_limit: 2000m
        memory_limit: 4Gi
    grafana:
      image: grafana/grafana:11.6.0
      replicas: 1
      ui_port: 3000
      resources:
        cpu_request: 100m
        memory_request: 256Mi
        cpu_limit: 500m
        memory_limit: 512Mi
    include_overview_dashboard: true
    dashboards: []
    storage:
      retain_on_destroy: false
      disk_type: pd-standard
      prometheus_storage_size: 20Gi
    timeouts:
      statefulset: 300
      deployment: 300
      load_balancer: 300
infrastructures:
  staging-gcp:
    disabled: false
    template: staging-gke
    account: my-gcp-account
    region: us-west1
    zones:
    - a
    zone_spread: SINGLE
  staging-aws:
    disabled: false
    template: staging-eks
    account: my-aws-account
    region: us-west-2
    zones:
    - a
    zone_spread: SINGLE
infrastructure_accounts:
  my-gcp-account:
    disabled: false
    provider: gcp
    gke_account: <YOUR_GCP_ACCOUNT_EMAIL>
    gke_project: <YOUR_GCP_PROJECT_ID>
  my-aws-account:
    disabled: false
    provider: aws
    aws_profile: <YOUR_AWS_PROFILE>
    aws_account: <YOUR_AWS_ACCOUNT_ID>
infrastructure_templates:
  staging-gke:
    disabled: false
    platform: gke
    k8s_default_pool_template: default-gke-pool
    k8s_requested_default_nodes: 1
    k8s_min_default_nodes: 1
    k8s_max_default_nodes: 3
  staging-eks:
    disabled: false
    platform: eks
    eks_kubernetes_version: 1.32
    k8s_default_pool_template: default-eks-pool
    k8s_requested_default_nodes: 1
    k8s_min_default_nodes: 1
    k8s_max_default_nodes: 3
node_pool_templates:
  default-gke-pool:
    platform: gke
    gke_machine_type: e2-standard-4
    gke_disk_type: pd-standard
    gke_disk_size: 20GB
    gke_local_ssd_count: 0
    gke_enable_autorepair: true
    gke_enable_autoupgrade: false
    gke_enable_ip_alias: true
    gke_node_external_ips: true
  cc-gke-pool:
    platform: gke
    gke_machine_type: n2d-standard-4
    gke_disk_type: pd-standard
    gke_disk_size: 20GB
    gke_local_ssd_count: 0
    gke_enable_autorepair: true
    gke_enable_autoupgrade: false
    gke_enable_ip_alias: true
    gke_node_external_ips: true
  cluster-gke-pool:
    platform: gke
    gke_machine_type: n2-highmem-8
    gke_disk_type: pd-standard
    gke_disk_size: 20GB
    gke_local_ssd_count: 1
    gke_enable_autorepair: true
    gke_enable_autoupgrade: false
    gke_enable_ip_alias: true
    gke_node_external_ips: true
  default-eks-pool:
    platform: eks
    eks_instance_type: m5.xlarge
    eks_volume_type: gp3
    eks_volume_size: 20GB
    eks_ami_type: AmazonLinux2023
    eks_capacity_type: ON_DEMAND
    eks_local_nvme_count: 0
    eks_enable_autoupgrade: false
    eks_endpoint_public_access: true
  cc-eks-pool:
    platform: eks
    eks_instance_type: r5.2xlarge
    eks_volume_type: gp3
    eks_volume_size: 20GB
    eks_ami_type: AmazonLinux2023
    eks_capacity_type: ON_DEMAND
    eks_local_nvme_count: 0
    eks_enable_autoupgrade: false
    eks_endpoint_public_access: true
  cluster-eks-pool:
    platform: eks
    eks_instance_type: r5.2xlarge
    eks_volume_type: gp3
    eks_volume_size: 20GB
    eks_ami_type: AmazonLinux2023
    eks_capacity_type: ON_DEMAND
    eks_local_nvme_count: 0
    eks_enable_autoupgrade: false
    eks_endpoint_public_access: true
cluster_templates:
  gke-standard-v9:
    disabled: false
    platform: gke
    version: 9.1.21
    nodes: 2
    replicas: 1
    management_port: 10300
    client_port: 10800
    discovery_port: 3344
    multicast:
      group: 239.192.0.0
      port: 47401
      result_wait_time: 500
      ttl: -1
    metastorage_node_limit: 3
    resources:
      limits:
        cpu: 3000m
        memory: 10Gi
      requests:
        cpu: 2000m
        memory: 8Gi
      data_storage:
        size: 10Gi
    telemetry:
      service_port: 3200
      sources:
      - client.handler
      - clock.service
      - expiration
      - index.builder
      - jvm
      - license
      - log.storage
      - messaging
      - metastorage
      - os
      - placement-driver
      - raft
      - raft.snapshots
      - resource.vacuum
      - sql.client
      - sql.memory
      - sql.offloading
      - sql.plan.cache
      - sql.queries
      - storage.aipersist
      - storage.aipersist.checkpoint
      - thread.pools.*
      - topology.*
      - transactions
      - upgrade.rolling
    k8s_image:
      repository: gridgain/gridgain9
      pull_policy: IfNotPresent
      pull_secrets: []
    k8s_node_pool_template: cluster-gke-pool
    k8s_storage:
      retain_on_cluster_destroy: false
      disk_type: pd-ssd
      volume_binding_mode: WaitForFirstConsumer
    pvc_retention_policy:
      enabled: false
      when_scaled: Retain
      when_deleted: Retain
    extra_env_vars: []
    extra_volume_mounts: []
    extra_volumes: []
    job_resources:
      limits:
        cpu: 500m
        memory: 512Mi
      requests:
        cpu: 250m
        memory: 256Mi
    statefulset_policy:
      pod_management_policy: Parallel
      update_strategy_type: RollingUpdate
      update_strategy_partition: 0
      revision_history_limit: 10
      work_dir: /gg9-work
    snapshot_profiles: {}
    pod_lifecycle:
      termination_grace_period_seconds: 180
      liveness_probe:
        enabled: true
        path: /management/v1/node/state
        port: 10300
        initial_delay_seconds: 60
        period_seconds: 20
        timeout_seconds: 5
        success_threshold: 1
        failure_threshold: 3
      readiness_probe:
        enabled: true
        path: /management/v1/node/state
        port: 10300
        initial_delay_seconds: 30
        period_seconds: 10
        timeout_seconds: 5
        success_threshold: 1
        failure_threshold: 3
      startup_probe:
        enabled: false
        path: /management/v1/node/state
        port: 10300
        initial_delay_seconds: 10
        period_seconds: 10
        timeout_seconds: 5
        success_threshold: 1
        failure_threshold: 30
  gke-standard-v8:
    disabled: false
    platform: gke
    version: 8.9.20
    nodes: 2
    replicas: 1
    management_port: 8080
    client_port: 10800
    discovery_port: 47500
    multicast:
      group: 228.1.2.4
      port: 47400
      result_wait_time: 2000
      ttl: 5
    metastorage_node_limit: 3
    resources:
      limits:
        cpu: 3000m
        memory: 10Gi
      requests:
        cpu: 2000m
        memory: 8Gi
      data_storage:
        size: 10Gi
    data_models: []
    base_data: []
    telemetry:
      service_port: 3200
      sources:
      - jvm
      - os
    k8s_image:
      repository: gridgain/ultimate
      tag: 8.9.20-p2-openjdk17
      pull_policy: IfNotPresent
      pull_secrets: []
    k8s_node_pool_template: cluster-gke-pool
    k8s_storage:
      retain_on_cluster_destroy: false
      disk_type: pd-ssd
      volume_binding_mode: WaitForFirstConsumer
    pvc_retention_policy:
      enabled: false
      when_scaled: Retain
      when_deleted: Retain
    extra_env_vars: []
    extra_volume_mounts: []
    extra_volumes: []
    job_resources:
      limits:
        cpu: 500m
        memory: 512Mi
      requests:
        cpu: 250m
        memory: 256Mi
    statefulset_policy:
      pod_management_policy: Parallel
      update_strategy_type: RollingUpdate
      update_strategy_partition: 0
      revision_history_limit: 10
      work_dir: /opt/ignite/work
    snapshot_profiles: {}
    persistence_enabled: true
    pod_lifecycle:
      termination_grace_period_seconds: 180
      liveness_probe:
        enabled: false
        path: /
        port: 8080
        initial_delay_seconds: 0
        period_seconds: 10
        timeout_seconds: 1
        success_threshold: 1
        failure_threshold: 3
      readiness_probe:
        enabled: false
        path: /
        port: 8080
        initial_delay_seconds: 0
        period_seconds: 10
        timeout_seconds: 1
        success_threshold: 1
        failure_threshold: 3
      startup_probe:
        enabled: false
        path: /
        port: 8080
        initial_delay_seconds: 0
        period_seconds: 10
        timeout_seconds: 1
        success_threshold: 1
        failure_threshold: 30
  eks-standard-v9:
    disabled: false
    platform: eks
    version: 9.1.21
    nodes: 1
    replicas: 1
    management_port: 10300
    client_port: 10800
    discovery_port: 3344
    multicast:
      group: 239.192.0.0
      port: 47401
      result_wait_time: 500
      ttl: -1
    metastorage_node_limit: 3
    resources:
      limits:
        cpu: 3000m
        memory: 10Gi
      requests:
        cpu: 2000m
        memory: 8Gi
      data_storage:
        size: 10Gi
    telemetry:
      service_port: 3200
      sources:
      - raft
    k8s_image:
      repository: gridgain/gridgain9
      pull_policy: IfNotPresent
    k8s_node_pool_template: cluster-eks-pool
    k8s_storage:
      retain_on_cluster_destroy: false
      disk_type: gp3
    pvc_retention_policy:
      enabled: false
      when_scaled: Retain
      when_deleted: Retain
    extra_env_vars: []
    extra_volume_mounts: []
    extra_volumes: []
    job_resources:
      limits:
        cpu: 500m
        memory: 512Mi
      requests:
        cpu: 250m
        memory: 256Mi
    statefulset_policy:
      pod_management_policy: Parallel
      update_strategy_type: RollingUpdate
      update_strategy_partition: 0
      revision_history_limit: 10
      work_dir: /gg9-work
    snapshot_profiles: {}
    pod_lifecycle:
      termination_grace_period_seconds: 180
      liveness_probe:
        enabled: true
        path: /management/v1/node/state
        port: 10300
        initial_delay_seconds: 60
        period_seconds: 20
        timeout_seconds: 5
        success_threshold: 1
        failure_threshold: 3
      readiness_probe:
        enabled: true
        path: /management/v1/node/state
        port: 10300
        initial_delay_seconds: 30
        period_seconds: 10
        timeout_seconds: 5
        success_threshold: 1
        failure_threshold: 3
      startup_probe:
        enabled: false
        path: /management/v1/node/state
        port: 10300
        initial_delay_seconds: 10
        period_seconds: 10
        timeout_seconds: 5
        success_threshold: 1
        failure_threshold: 30
  eks-standard-v8:
    disabled: false
    platform: eks
    version: 8.9.20
    nodes: 2
    replicas: 1
    management_port: 8080
    client_port: 10800
    discovery_port: 47500
    multicast:
      group: 228.1.2.4
      port: 47400
      result_wait_time: 2000
      ttl: 5
    metastorage_node_limit: 3
    resources:
      limits:
        cpu: 3000m
        memory: 10Gi
      requests:
        cpu: 2000m
        memory: 8Gi
      data_storage:
        size: 10Gi
    data_models: []
    base_data: []
    telemetry:
      service_port: 3200
      sources:
      - jvm
      - os
    k8s_image:
      repository: gridgain/ultimate
      tag: 8.9.20-p2-openjdk17
      pull_policy: IfNotPresent
      pull_secrets: []
    k8s_node_pool_template: cluster-eks-pool
    k8s_storage:
      retain_on_cluster_destroy: false
      disk_type: gp3
      volume_binding_mode: WaitForFirstConsumer
    pvc_retention_policy:
      enabled: false
      when_scaled: Retain
      when_deleted: Retain
    extra_env_vars: []
    extra_volume_mounts: []
    extra_volumes: []
    job_resources:
      limits:
        cpu: 500m
        memory: 512Mi
      requests:
        cpu: 250m
        memory: 256Mi
    statefulset_policy:
      pod_management_policy: Parallel
      update_strategy_type: RollingUpdate
      update_strategy_partition: 0
      revision_history_limit: 10
      work_dir: /opt/ignite/work
    persistence_enabled: true
    snapshot_profiles: {}
    pod_lifecycle:
      termination_grace_period_seconds: 180
      liveness_probe:
        enabled: false
        path: /
        port: 8080
        initial_delay_seconds: 0
        period_seconds: 10
        timeout_seconds: 1
        success_threshold: 1
        failure_threshold: 3
      readiness_probe:
        enabled: false
        path: /
        port: 8080
        initial_delay_seconds: 0
        period_seconds: 10
        timeout_seconds: 1
        success_threshold: 1
        failure_threshold: 3
      startup_probe:
        enabled: false
        path: /
        port: 8080
        initial_delay_seconds: 0
        period_seconds: 10
        timeout_seconds: 1
        success_threshold: 1
        failure_threshold: 30
connector_templates:
  gke-connector:
    type: cloud-connector
    platform: gke
    k8s_node_pool_template: default-gke-pool
    k8s_service_name: gg-cc-svc
    k8s_app_tag: cloud-connector
    k8s_replicas: 1
    k8s_listener_port: 8080
    exporter_target_hostname: gg-connector
    exporter_target_port: 3200
  eks-connector:
    type: cloud-connector
    platform: eks
    k8s_node_pool_template: default-eks-pool
    k8s_service_name: gg-cc-svc
    k8s_app_tag: cloud-connector
    k8s_replicas: 1
    k8s_listener_port: 8080
    exporter_target_hostname: gg-connector
    exporter_target_port: 3200
  gke-otel-collector:
    type: otel-collector
    platform: gke
    k8s_node_pool_template: default-gke-pool
    k8s_service_name: otel-collector-svc
    k8s_http_listener_port: 4318
    k8s_app_tag: otel-collector
    k8s_replicas: 1
    k8s_listener_port: 4317
    k8s_cpu_request: 250m
    k8s_memory_request: 256Mi
    k8s_cpu_limit: 500m
    k8s_memory_limit: 512Mi
    k8s_job_cpu_request: 100m
    k8s_job_memory_request: 128Mi
    k8s_job_cpu_limit: 250m
    k8s_job_memory_limit: 256Mi
    export_period_millis: 5000
  ignite-agent:
    type: ignite-agent
